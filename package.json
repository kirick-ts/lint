{
	"name": "@kirick/lint",
	"version": "0.2.13",
	"publishConfig": {
		"access": "public"
	},
	"type": "module",
	"bin": "dist/main.js",
	"exports": {
		"./eslint/common": "./configs/eslint/common.js",
		"./eslint/node": "./configs/eslint/node.js",
		"./eslint/oxlint": "./configs/eslint/oxlint.js",
		"./eslint/vue": "./configs/eslint/vue.js"
	},
	"engines": {
		"node": ">=22.16"
	},
	"dependencies": {
		"@stylistic/eslint-plugin": "5.10.0",
		"eslint": "10.2.0",
		"eslint-plugin-jsdoc": "62.9.0",
		"eslint-plugin-n": "17.24.0",
		"eslint-plugin-promise": "7.2.1",
		"eslint-plugin-unicorn": "64.0.0",
		"eslint-plugin-vue": "10.8.0",
		"typescript-eslint": "8.58.0"
	},
	"devDependencies": {
		"@biomejs/biome": "2.3.11",
		"@types/bun": "1.3.11",
		"oxlint": "1.58.0",
		"prettier": "3.6.2",
		"publint": "0.3.16",
		"tsdown": "0.15.11",
		"type-fest": "5.4.1",
		"typescript": "5.9.3",
		"valibot": "1.2.0"
	},
	"scripts": {
		"build": "tsdown src/main.ts --dts=false --format esm",
		"check": "bun run lint && bun run build && bun run test",
		"lint": "biome format && oxlint && eslint . && tsc",
		"lint:prettier": "prettier --check **/*.vue",
		"test": "echo 'No tests available'",
		"# postinstall": "bun run --bun dist/main.js",
		"rules": "bun test/rules.ts"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/kirick-ts/lint.git"
	},
	"keywords": [],
	"author": "Daniil Kirichenko (https://twitter.com/kirickme)",
	"license": "MIT",
	"bugs": {
		"url": "https://github.com/kirick-ts/lint/issues"
	},
	"homepage": "https://github.com/kirick-ts/lint#readme"
}
